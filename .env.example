# =============================================================================
# Copy to .env (gitignored). Both backend and frontend read from this file
# locally via docker-compose / dotenv. On Railway, set these as service vars.
# =============================================================================

# --- Shared auth ---
# Single shared password for all internal users (MVP).
APP_PASSWORD=change-me

# Used to sign the auth cookie. Generate: `openssl rand -hex 32`
AUTH_SECRET=change-me-to-32-bytes-of-random-hex

# --- Backend ---
# Postgres connection string (docker-compose default below).
DATABASE_URL=postgresql+psycopg://rich:rich@localhost:5432/rich

# CORS origin for the frontend (comma-separated for multiple).
FRONTEND_ORIGIN=http://localhost:3000

# Claude API for deep analysis (Phase 3+).
ANTHROPIC_API_KEY=
# Optional: point the Anthropic SDK at a proxy/wrapper service.
# Example: https://zenmux.ai/api/anthropic
# Leave empty to use the official api.anthropic.com endpoint.
ANTHROPIC_BASE_URL=

# Set False to disable the in-process APScheduler (e.g., when running tests
# or scaling backend to >1 replica — only one should schedule).
SCHEDULER_ENABLED=true

# --- Frontend ---
# URL the browser uses to reach the backend.
NEXT_PUBLIC_API_BASE=http://localhost:8000
