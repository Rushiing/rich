# =============================================================================
# Copy to .env (gitignored). Both backend and frontend read from this file
# locally via docker-compose / dotenv. On Railway, set these as service vars.
# =============================================================================

# --- Shared auth ---
# Single shared password for all internal users (MVP).
APP_PASSWORD=change-me

# Used to sign the auth cookie. Generate: `openssl rand -hex 32`
AUTH_SECRET=change-me-to-32-bytes-of-random-hex

# --- Backend ---
# Postgres connection string (docker-compose default below).
DATABASE_URL=postgresql+psycopg://rich:rich@localhost:5432/rich

# CORS origin for the frontend (comma-separated for multiple).
FRONTEND_ORIGIN=http://localhost:3000

# Analysis LLM (any Anthropic-compatible gateway).
# Production currently runs Aliyun dashscope's coding plan (free, see
# CLAUDE.md "Analysis model" section for the why).
ANTHROPIC_API_KEY=
# Gateway base URL. Examples:
#   official:   (leave blank, uses api.anthropic.com)
#   zenmux:     https://zenmux.ai/api/anthropic
#   dashscope:  https://coding.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_BASE_URL=
# Model name to send. Empty = code default (currently kimi-k2.5).
# On zenmux: claude-sonnet-4-6 / claude-opus-4-6 / etc.
# On dashscope: kimi-k2.5 / qwen3-max-2026-01-23 / MiniMax-M2.5 / glm-4.7 / ...
ANALYSIS_MODEL=

# Model A/B (6/10): send ANALYSIS_AB_PCT% of (code, day) buckets to a second
# model; outcome anchors record which model produced each verdict, so
# /api/_diag/outcomes-stats can compare hit rates per model after 2-4 weeks.
# Model B goes through the SAME gateway/key as model A — pick a name the
# current ANTHROPIC_BASE_URL serves (dashscope: MiniMax-M2.5 / glm-4.7 ...).
# Leave empty / 0 to disable.
ANALYSIS_MODEL_B=
ANALYSIS_AB_PCT=0

# --- 单股深挖档 (deep mode, 6/29) ---
# 详情页「🧠 深度研究」走的独立路径:OpenAI 兼容协议 + thinking 模型(~90s)。
# 该 provider 的 Anthropic 兼容层对 thinking 模型坏,故 deep 单独走 OpenAI 协议。
# batch/single/debate 不受影响(仍走 ANTHROPIC_*)。**留空 ANALYSIS_DEEP_MODEL
# = 深挖档禁用**(mode=deep 返回 503)。
OPENAI_COMPAT_BASE_URL=        # 形如 https://<host>/compatible-mode/v1
OPENAI_COMPAT_API_KEY=         # 留空则 fallback 到 ANTHROPIC_API_KEY
ANALYSIS_DEEP_MODEL=           # 推荐 qwen3.7-max;空 = 禁用
# qwen/deepseek stream 下默认就 thinking(更快);只有 kimi 系列需设 true。
ANALYSIS_DEEP_ENABLE_THINKING=false

# Set False to disable the in-process APScheduler (e.g., when running tests
# or scaling backend to >1 replica — only one should schedule).
SCHEDULER_ENABLED=true

# --- Phase 6: SMS auth + admin migration ---
# Aliyun SMS credentials. Leave blank to run in dev mode (verification
# code fixed at SMS_DEV_CODE, only SMS_DEV_WHITELIST phones can sign in).
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
SMS_DEV_CODE=8888
# Comma-separated 11-digit phones permitted to sign in while ALIYUN_*
# is empty. Add your test phones here, e.g. 13800000001,13800000002
SMS_DEV_WHITELIST=

# Admin migration: at lifespan startup, ensure a User row with this phone
# exists and assign every NULL-user_id watchlist row to that user. Idempotent.
# Set this to your phone number on Railway before the first Phase 6 deploy
# so existing 61 watchlist rows auto-migrate to your account.
ADMIN_PHONE=

# --- Frontend ---
# URL the browser uses to reach the backend.
NEXT_PUBLIC_API_BASE=http://localhost:8000
